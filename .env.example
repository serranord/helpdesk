# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=helpdesk_dr
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=480

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
