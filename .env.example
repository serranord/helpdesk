APP_NAME="HelpDesk DR"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_TIMEZONE=America/Santo_Domingo

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
